generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

  moduleFormat        = "esm"
  importFileExtension = "js"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/generated/"
  config   = "./generator.config.json"
}

datasource db {
  provider = "postgresql"
}

model User {
  pk       Int       @id @default(autoincrement())
  id       String    @unique @default(cuid())
  name     String    @unique
  blocked  User[]    @relation("blocked")
  password String
  messages Message[] @relation("UserMessages")

  bookmarks        Message[]          @relation("UserBookmarks")
  conversations    Conversation[]
  bio              String             @default("")
  imgUrl           String
  blockedBy        User[]             @relation("blocked")
  messageReceipts  MessageReceipt[]
  messageReactions MessageReactions[]
}

model Message {
  id               String             @id @default(cuid())
  body             String
  createdAt        DateTime           @default(now())
  deliveredAt      DateTime?
  authorId         String
  conversationId   String?
  author           User               @relation("UserMessages", fields: [authorId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  conversation     Conversation?      @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookmarkedBy     User[]             @relation("UserBookmarks")
  status           MessageStatus      @default(PENDING)
  messageReceipts  MessageReceipt[]
  messageReactions MessageReactions[]
}

model MessageReceipt {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model MessageReactions {
  id        String  @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model Conversation {
  id        String    @id @default(cuid())
  messages  Message[]
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum MessageStatus {
  PENDING
  DELIVERED
  READ
}
