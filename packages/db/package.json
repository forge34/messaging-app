{
  "name": "@chat/db",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:push": "pnpm prisma db push",
    "db:reset": "pnpm prisma db push --force-reset",
    "db:generate": "pnpm prisma generate  && pnpm build",
    "db:migrate": "pnpm prisma migrate dev",
    "watch": "tsc -w  -p tsconfig.json"
  },
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "pg": "^8.17.1",
    "prisma-zod-generator": "^2.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "prisma": "^7.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
