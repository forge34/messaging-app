{
  "name": "chat",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev:packages": "pnpm --filter \"./packages/**\" run --parallel dev",
    "dev:server": "pnpm --filter ./apps/server  start:dev",
    "dev:client": "pnpm --filter ./apps/client dev",
    "build:packages": "pnpm --filter \"./packages/**\" run --r build",
    "build:shared": "pnpm --filter ./packages/shared/ build",
    "build:server": "pnpm --filter ./apps/server/ build",
    "build:client": "pnpm --filter ./apps/client/ build",
    "db:generate": "pnpm --filter ./packages/db db:generate",
    "db:migrate": "pnpm --filter @chat/db db:migrate",
    "db:reset" :"pnpm --filter @chat/db db:reset",
    "db:studio": "pnpm --filter @chat/db db:studio",
    "dev": "pnpm --parallel run dev",
    "build": "pnpm -r run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "zod": "^4.3.6"
  }
}
